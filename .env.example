DATABASE_URL=postgres://yuksales:yuksales@localhost:5432/yuksales
SUPABASE_DATABASE=false
# Jika SUPABASE_DATABASE=true, pakai salah satu:
# 1) URL pooler Supabase lengkap, direkomendasikan untuk koneksi dari lokal/serverless.
SUPABASE_POOLER_DATABASE_URL=
# 2) URL direct Supabase lengkap.
SUPABASE_DATABASE_URL=
# 3) Atau project ref + password untuk auto-build pooler URL.
SUPABASE_PROJECT_REF=
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_SECONDS=20
DB_CONNECT_TIMEOUT_SECONDS=30
API_PORT=4000
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5173,https://127.0.0.1:5173
API_HTTPS_ENABLED=true
API_TLS_KEY_PATH=192.168.18.66+2-key.pem
API_TLS_CERT_PATH=192.168.18.66+2.pem
REFRESH_COOKIE_NAME=yuksales_refresh_token
REFRESH_COOKIE_SECURE=true
VITE_API_BASE_URL=https://localhost:4000
VITE_DEV_HTTPS_ENABLED=true
VITE_DEV_TLS_KEY_PATH=192.168.18.66+2-key.pem
VITE_DEV_TLS_CERT_PATH=192.168.18.66+2.pem

