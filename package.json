{
  "name": "yuksales",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @yuksales/web --filter @yuksales/api dev",
    "dev:web": "pnpm --filter @yuksales/web dev",
    "dev:api": "pnpm --filter @yuksales/api dev",
    "build": "pnpm -r build",
    "build:all": "pnpm install && pnpm db:generate && pnpm db:migrate && pnpm --filter @yuksales/web build && pnpm --filter @yuksales/api build && pip3 install -r services/face-service/requirements.txt && pm2 delete yuksales-api yuksales-face-service 2>/dev/null; pm2 start \"pnpm --filter @yuksales/api start\" --name yuksales-api && pm2 start \"python3 services/face-service/app.py\" --name yuksales-face-service && pm2 save",
    "start:api": "pnpm --filter @yuksales/api start",
    "face:setup:linux": "sh services/face-service/setup-linux.sh",
    "face:setup:windows": "powershell -ExecutionPolicy Bypass -File services/face-service/setup-windows.ps1",
    "face:start": "python services/face-service/app.py",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @yuksales/db db:generate",
    "db:migrate": "pnpm --filter @yuksales/db db:migrate",
    "db:studio": "pnpm --filter @yuksales/db db:studio",
    "db:seed": "pnpm --filter @yuksales/db db:seed",
    "db:seedcompany": "pnpm --filter @yuksales/db db:seedcompany",
    "db:fresh": "pnpm --filter @yuksales/db db:fresh",
    "db:debug": "pnpm --filter @yuksales/db db:debug",
    "db:repair-migrations": "pnpm --filter @yuksales/db db:repair-migrations"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "latest",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "latest",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "xlsx-js-style": "^1.2.0"
  }
}
